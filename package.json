{
  "name": "@smartmarbles/synapcli",
  "version": "1.0.0",
  "description": "Sync files from a GitHub repository into any project — built for AI-assisted development teams sharing agent definitions, system prompts, copilot instructions, coding standards, scripts, resources, and any other AI model assets across a portfolio of projects.",
  "type": "module",
  "bin": {
    "synap": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartmarbles/synapcli.git"
  },
  "homepage": "https://github.com/smartmarbles/synapcli#readme",
  "bugs": {
    "url": "https://github.com/smartmarbles/synapcli/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build",
    "preuninstall": "node scripts/preuninstall.mjs"
  },
  "keywords": ["cli", "agents", "prompts", "llm", "ai", "github", "sync", "copilot", "devtools"],
  "author": "SmartMarbles.com",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "chalk": "5.6.2",
    "cli-progress": "3.12.0",
    "commander": "14.0.3",
    "diff": "8.0.4",
    "ora": "9.3.0",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/cli-progress": "3.11.6",
    "@types/node": "25.5.0",
    "@types/picomatch": "4.0.2",
    "@vitest/coverage-v8": "4.1.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md",
    "LICENSE"
  ]
}
