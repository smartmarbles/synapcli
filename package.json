{
  "name": "synapcli",
  "version": "0.2.0",
  "description": "Pull agent and prompt files from a GitHub repository into your JS project",
  "type": "module",
  "bin": {
    "synap": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["cli", "agents", "prompts", "llm", "ai", "github"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "micromatch": "^4.0.8",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/diff": "^6.0.0",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
